# ** Development configuration

# Local database settings for development
DATABASE_URI=mysql+mysqlconnector://root:your_local_password@localhost/your_local_db

# JWT secret for development (use a different one than production)
JWT_SECRET_KEY=development-secret-key

# If your frontend uses environment variables, for example:
VITE_API_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:3000


