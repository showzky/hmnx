# Backend production configuration
# Use your hosted database URL here, for example the Supabase pooled connection string.
DATABASE_URI=postgresql+psycopg://postgres:replace-me@aws-0-region.pooler.supabase.com:6543/postgres
JWT_SECRET_KEY=replace-with-a-production-secret
FLASK_SECRET_KEY=replace-with-a-stable-production-session-secret
FLASK_ENV=production
FRONTEND_URL=https://your-frontend-domain.example
BACKEND_URL=https://your-backend-domain.example
DISCORD_CLIENT_ID=1356200673636515922
DISCORD_CLIENT_SECRET=replace-with-your-discord-client-secret
STEAM_WEB_API_KEY=replace-with-your-steam-web-api-key
OPENXBL_API_KEY=replace-with-your-openxbl-api-key
MICROSOFT_CLIENT_ID=replace-with-your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=replace-with-your-microsoft-client-secret
MICROSOFT_TENANT_ID=common

SUPPORT_SERVER=mail.example.com
SUPPORT_PORT=587
SUPPORT_USE_TLS=true
SUPPORT_USERNAME=production-support@example.com
SUPPORT_PASSWORD=replace-me
SUPPORT_DEFAULT_SENDER=production-support@example.com

MAILERSEND_SERVER=smtp.mailersend.net
MAILERSEND_PORT=2525
MAILERSEND_USE_TLS=true
MAILERSEND_USERNAME=replace-me
MAILERSEND_PASSWORD=replace-me
MAILERSEND_DEFAULT_SENDER=replace-me@example.com
